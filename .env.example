# Required for Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
ENABLE_GOOGLE_AUTH=false
STAFF_LOGIN_EMAIL=sales@scalify.ae
STAFF_LOGIN_PASSWORD=replace-with-a-strong-password
SESSION_SECRET=replace-with-a-long-random-string
DATA_DIR=./data

# Optional: only for local testing without Google OAuth. Must still use @scalify.ae email.
ALLOW_DEV_LOGIN=false

# Warehouse email alerts for new/updated/deleted orders.
# Gmail works with an App Password, not the normal mailbox password.
WAREHOUSE_EMAIL=sales@scalify.ae
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=sales@scalify.ae
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Rekart OMS <sales@scalify.ae>"

# Optional: enables automatic WhatsApp Cloud API sending.
# Without these, OMS stores a wa.me notification link in data/rekart.db.
WHATSAPP_CLOUD_TOKEN=your-whatsapp-cloud-api-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
