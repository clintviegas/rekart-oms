# Backend — copy to backend/.env
BACKEND_PORT=4000
NODE_ENV=development

# MongoDB (required)
MONGODB_URI=mongodb://127.0.0.1:27017/rekart_oms

# Auth secrets (change in production)
JWT_SECRET=replace-with-a-long-random-string
REFRESH_SECRET=replace-with-a-long-refresh-secret
CSRF_SECRET=replace-with-a-csrf-secret
PENDING_2FA_SECRET=replace-with-a-pending-2fa-secret

# Seed admin user (first run only)
STAFF_LOGIN_EMAIL=sales@scalify.ae
STAFF_LOGIN_PASSWORD=replace-with-a-strong-password

DATA_DIR=./data
WEB_ORIGIN=http://localhost:3000
DEFAULT_TENANT_SLUG=scalify
TENANT_BASE_DOMAIN=localhost

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry (optional)
SENTRY_DSN=

# Password reset
PASSWORD_RESET_TTL_MS=3600000

# Auto backups — requires mongodump in PATH
BACKUP_CRON_ENABLED=true
BACKUP_CRON_SCHEDULE=0 2 * * *
BACKUP_RETENTION_COUNT=7

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# SMTP — warehouse alerts + password reset emails
WAREHOUSE_EMAIL=sales@scalify.ae
WAREHOUSE_WHATSAPP=+971545192005
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=sales@scalify.ae
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Rekart OMS <sales@scalify.ae>

# WhatsApp Cloud API (optional)
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
