# Frontend — copy to frontend/.env.local (or frontend/.env)

# Backend API (Next.js rewrites /api → backend)
BACKEND_URL=http://localhost:4000

# Google Sign-In button (optional — must match backend GOOGLE_CLIENT_ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Playwright E2E (optional — full login test)
E2E_LOGIN_EMAIL=
E2E_LOGIN_PASSWORD=
PLAYWRIGHT_BASE_URL=http://localhost:3000
